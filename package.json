{
  "name": "mutx",
  "version": "1.4.0",
  "private": true,
  "license": "BUSL-1.1",
  "packageManager": "npm@10.7.0",
  "main": "desktop/main.cjs",
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('public/_next', { recursive: true, force: true })\"",
    "postbuild": "node scripts/fix-next-types.mjs",
    "prepare:standalone": "node scripts/prepare-standalone.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "npm run prepare:standalone && node scripts/start-standalone.mjs",
    "lint": "eslint . --max-warnings=0",
    "desktop:start": "npm run prepare:standalone && npx electron .",
    "desktop:dev": "bash -lc 'npm run dev & NEXT_PID=$!; trap \"kill $NEXT_PID\" EXIT; until curl -fsS http://127.0.0.1:3000 >/dev/null; do sleep 1; done; MUTX_DESKTOP_URL=http://127.0.0.1:3000 npx electron .'",
    "desktop:signing-check": "node desktop/scripts/check-signing-env.js",
    "desktop:package:release": "npm run prepare:standalone && node desktop/scripts/package-release.js",
    "desktop:build": "npm run build && npm run desktop:package:release",
    "desktop:build:arm64": "npm run build && npm run prepare:standalone && node desktop/scripts/package-release.js --arch=arm64",
    "desktop:build:x64": "npm run build && npm run prepare:standalone && node desktop/scripts/package-release.js --arch=x64",
    "desktop:checksums": "bash desktop/scripts/generate-checksums.sh",
    "desktop:launch:smoke": "node desktop/scripts/launch-built-app.js",
    "desktop:release:validate": "npm run desktop:signing-check && npm run desktop:package:release && npm run desktop:notarize:release && npm run desktop:notarize:status && npm run desktop:checksums && npm run desktop:launch:smoke",
    "desktop:notarize:release": "node desktop/scripts/notarize-release.js",
    "desktop:notarize:status": "node desktop/scripts/check-notarization.js",
    "desktop:notarize:latest": "node desktop/scripts/notarize-existing.js",
    "desktop:verify:artifacts": "node desktop/scripts/verify-release-artifacts.js",
    "generate:contracts": "bash scripts/generate-contract-artifacts.sh",
    "generate-types": "openapi-typescript docs/api/openapi.json -o app/types/api.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:app",
    "test:app": "jest --runInBand tests/unit",
    "test:e2e:dashboard": "playwright test tests/dashboardAgents.spec.ts tests/dashboardOpenClaw.spec.ts tests/dashboardRouteMatrix.spec.ts --project=chromium --workers=1",
    "test:e2e:release": "bash scripts/run-release-web-smoke.sh",
    "demo:validate": "bash scripts/demo-validate.sh",
    "release:promote:railway": "bash scripts/promote-railway-production.sh",
    "release:verify:production": "bash scripts/verify-production-release.sh",
    "release:check": "bash scripts/release-check.sh",
    "build:docs-search": "npx tsx scripts/build-docs-search-index.ts",
    "docs:watch": "npx tsx scripts/docs-watcher.ts"
  },
  "build": {
    "appId": "dev.mutx.desktop",
    "productName": "MUTX",
    "directories": {
      "output": "dist/desktop"
    },
    "files": [
      "desktop/**/*",
      "cli/**/*",
      "scripts/start-standalone.mjs",
      "src/**/*",
      "package.json",
      ".next/**/*"
    ],
    "asarUnpack": [
      ".next/standalone/**/*",
      ".next/standalone/.next/**/*",
      "cli/**/*",
      "scripts/start-standalone.mjs",
      "src/**/*"
    ],
    "extraMetadata": {
      "main": "desktop/main.cjs"
    },
    "artifactName": "${productName}-${version}-macos-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "desktop/Resources/icon.png",
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "desktop/entitlements.plist",
      "entitlementsInherit": "desktop/entitlements.plist"
    },
    "afterSign": "desktop/scripts/notarize.js",
    "asar": true,
    "compression": "normal"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@resvg/resvg-js": "^2.6.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.35.2",
    "geist": "^1.7.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "lenis": "^1.1.9",
    "lucide-react": "^0.323.0",
    "next": "16.2.3",
    "next-intl": "^4.9.1",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-intersection-observer": "^9.13.1",
    "react-turnstile": "^1.1.5",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "resend": "^6.9.3",
    "satori": "^0.26.0",
    "sharp": "^0.33.5",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.4.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@electron/notarize": "^3.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "@types/node": "25.3.5",
    "@types/pg": "^8.18.0",
    "@types/react": "19.2.14",
    "@types/three": "^0.169.0",
    "autoprefixer": "^10.4.17",
    "electron": "^39.8.5",
    "electron-builder": "^26.0.12",
    "eslint": "^10.1.0",
    "eslint-config-next": "16.2.1",
    "fuse.js": "^7.3.0",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.35",
    "sharp": "^0.33.5",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.4.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.5",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.2",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.12"
  }
}

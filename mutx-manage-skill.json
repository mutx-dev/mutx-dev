{
  "name": "mutx-manage",
  "version": "1.0.0",
  "description": "Manage a running MUTX instance — health checks, diagnostics, upgrades, backups",
  "author": "MUTX",
  "license": "MIT",
  "tools": ["exec", "http"],
  "parameters": {
    "base_url": {
      "type": "string",
      "default": "http://localhost:3000",
      "description": "MUTX base URL"
    },
    "api_key": {
      "type": "string",
      "description": "API key for authentication (x-api-key header)"
    }
  },
  "tags": ["mutx", "management", "health", "upgrade", "backup"]
}

# =============================================================================
# MUTX Production Environment Variables
# 
# Copy this file to .env.production and fill in your values
# Usage: cp production.env.example .env.production
# =============================================================================

# -----------------------------------------------------------------------------
# Required - Database
# -----------------------------------------------------------------------------
POSTGRES_USER=mutx
POSTGRES_PASSWORD=your-secure-password-min-16-chars
POSTGRES_DB=mutx
DATABASE_URL=postgresql://mutx:your-secure-password-min-16-chars@postgres:5432/mutx
# Set to "disable" only if your PostgreSQL endpoint rejects SSL
DATABASE_SSL_MODE=require
# Set to true if database must be available on startup
DATABASE_REQUIRED_ON_STARTUP=false

# -----------------------------------------------------------------------------
# Required - Security
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-min-32-chars
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secure-nextauth-secret-min-32-chars

# -----------------------------------------------------------------------------
# Required - URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.mutx.dev
NEXT_PUBLIC_SITE_URL=https://mutx.dev
NEXTAUTH_URL=https://mutx.dev

# -----------------------------------------------------------------------------
# Optional - Email (Resend)
# -----------------------------------------------------------------------------
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_resend_api_key

# -----------------------------------------------------------------------------
# Optional - Turnstile (Cloudflare)
# -----------------------------------------------------------------------------
# Get your keys from https://cloudflare.com/products/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# -----------------------------------------------------------------------------
# Optional - CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=https://mutx.dev,https://app.mutx.dev

# -----------------------------------------------------------------------------
# Optional - Redis
# -----------------------------------------------------------------------------
# Default: redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Optional - Server Configuration
# -----------------------------------------------------------------------------
# Number of worker processes for API
WEB_CONCURRENCY=4
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Optional - Ports
# -----------------------------------------------------------------------------
HTTP_PORT=80
HTTPS_PORT=443

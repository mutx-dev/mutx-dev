FROM node:24-alpine AS base
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1
RUN apk upgrade --no-cache && npm install -g npm@11.12.1

FROM base AS deps
COPY package.json package-lock.json ./
RUN npm ci --legacy-peer-deps

FROM base AS development
ENV NODE_ENV=development
COPY --from=deps /app/node_modules ./node_modules
COPY package.json package-lock.json ./
EXPOSE 3000
CMD ["npm", "run", "dev", "--", "--hostname", "0.0.0.0", "--port", "3000"]

FROM base AS builder
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN rm -rf public/_next
ARG NEXT_PUBLIC_API_URL=https://api.mutx.dev
ARG NEXT_PUBLIC_SITE_URL=https://mutx.dev
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_SITE_URL=${NEXT_PUBLIC_SITE_URL}
RUN npm run build

FROM base AS production
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
COPY --from=builder /app /app
# Next standalone does not bundle public assets or .next/static by default.
# Put them under the standalone runtime directory so `node .next/standalone/server.js`
# can resolve the same asset paths Railway serves in production.
COPY --from=builder /app/public /app/.next/standalone/public
COPY --from=builder /app/.next/static /app/.next/standalone/.next/static

EXPOSE 3000

CMD ["node", ".next/standalone/server.js"]

# Railway targets a `runner` stage for the frontend service.
# Keep an explicit alias here so the deployed image cannot drift to a
# different Dockerfile target or stale cached stage.
FROM production AS runner

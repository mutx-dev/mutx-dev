output "vpc_ids" {
  description = "VPC IDs for each customer"
  value       = { for idx, vpc in digitalocean_vpc.customer : var.customers[idx].id => vpc.id }
}

output "vpc_cidrs" {
  description = "VPC CIDR ranges for each customer"
  value       = { for idx, vpc in digitalocean_vpc.customer : var.customers[idx].id => vpc.ip_range }
}

output "droplet_ids" {
  description = "Droplet IDs for each customer"
  value       = { for idx, droplet in digitalocean_droplet.customer : var.customers[idx].id => droplet.id }
}

output "droplet_ips" {
  description = "Private IP addresses for each customer droplet"
  value       = { for idx, droplet in digitalocean_droplet.customer : var.customers[idx].id => droplet.ipv4_address_private }
}

output "droplet_public_ips" {
  description = "Public IP addresses for each customer droplet"
  value       = { for idx, droplet in digitalocean_droplet.customer : var.customers[idx].id => droplet.ipv4_address }
  sensitive   = true
}

output "connection_info" {
  description = "Connection information for each customer"
  value       = { for idx, droplet in digitalocean_droplet.customer : var.customers[idx].id => {
    host        = droplet.ipv4_address
    private_ip  = droplet.ipv4_address_private
    port        = 22
    user        = "root"
    }
  }
  sensitive = true
}

output "volume_ids" {
  description = "Volume IDs for each customer"
  value       = { for idx, volume in digitalocean_volume.customer : var.customers[idx].id => volume.id }
}

output "firewall_ids" {
  description = "Firewall IDs for each customer"
  value       = { for idx, fw in digitalocean_firewall.customer : var.customers[idx].id => fw.id }
}

output "project_ids" {
  description = "Project IDs for each customer"
  value       = { for idx, project in digitalocean_project.customer : var.customers[idx].id => project.id }
}

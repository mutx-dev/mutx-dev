resource "digitalocean_ssh_key" "customer" {
  count       = length(var.customers)
  name       = "${var.project_name}-${var.customers[count.index].id}-key"
  public_key = var.customers[count.index].ssh_key
}

resource "digitalocean_droplet" "customer" {
  count     = length(var.customers)
  name      = "${var.project_name}-${var.customers[count.index].id}-agent"
  region    = var.region
  size      = var.droplet_size
  image     = var.droplet_image
  vpc_uuid  = digitalocean_vpc.customer[count.index].id

  ssh_keys = [
    digitalocean_ssh_key.customer[count.index].fingerprint,
    var.admin_ssh_key_id,
  ]

  tags = [
    "customer:${var.customers[count.index].id}",
    "environment:${var.environment}",
    "type:agent",
    "managed-by:terraform",
  ]

  user_data = templatefile("${path.module}/templates/cloud-init.yaml.tpl", {
    customer_id       = var.customers[count.index].id
    agent_port        = var.agent_port
    agent_version     = var.agent_version
    telemetry_enabled = var.telemetry_enabled
    ssh_public_key    = var.customers[count.index].ssh_key
  })

  lifecycle {
    create_before_destroy = true
  }
}

resource "digitalocean_volume" "customer" {
  count      = length(var.customers)
  name       = "${var.project_name}-${var.customers[count.index].id}-data"
  region     = var.region
  size       = var.data_volume_size
  description = "Data volume for customer ${var.customers[count.index].id}"

  tags = [
    "customer:${var.customers[count.index].id}",
  ]
}

resource "digitalocean_volume_attachment" "customer" {
  count      = length(var.customers)
  droplet_id = digitalocean_droplet.customer[count.index].id
  volume_id  = digitalocean_volume.customer[count.index].id
}

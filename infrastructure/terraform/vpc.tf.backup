resource "digitalocean_vpc" "customer" {
  count          = length(var.customers)
  name           = "${var.project_name}-${var.customers[count.index].id}-vpc"
  region         = var.region
  ip_range       = var.customers[count.index].vpc_cidr
  description    = "VPC for customer ${var.customers[count.index].id}"
}

resource "digitalocean_firewall" "customer" {
  count  = length(var.customers)
  name   = "${var.project_name}-${var.customers[count.index].id}-fw"
  droplet_ids = [digitalocean_droplet.customer[count.index].id]

  inbound_rule {
    protocol         = "tcp"
    port_range       = "22"
    source_addresses = [var.admin_cidr]
  }

  inbound_rule {
    protocol         = "tcp"
    port_range       = "80-443"
    source_addresses = ["0.0.0.0/0"]
  }

  inbound_rule {
    protocol         = "tcp"
    port_range       = "${var.agent_port}"
    source_addresses = [digitalocean_vpc.customer[count.index].ip_range]
  }

  outbound_rule {
    protocol              = "tcp"
    port_range            = "443"
    destination_addresses  = ["0.0.0.0/0"]
  }

  outbound_rule {
    protocol              = "tcp"
    port_range            = "53"
    destination_addresses = ["0.0.0.0/0"]
  }
}

resource "digitalocean_project" "customer" {
  count        = length(var.customers)
  name         = "${var.project_name}-${var.customers[count.index].id}"
  description  = "Project for customer ${var.customers[count.index].id}"
  purpose      = "Hosting and infrastructure"
  environment  = var.environment

  resources = [
    digitalocean_vpc.customer[count.index].urn,
    digitalocean_droplet.customer[count.index].urn,
  ]
}

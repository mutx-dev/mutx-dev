{
  "version": "1.0.0",
  "generated": "2026-04-01",
  "auto_commit_rules": {
    "description": "Safe to commit without second-agent review. CI must pass.",
    "rules": [
      {
        "path": "docs/**",
        "description": "Docs-only changes, including API reference markdown",
        "max_files": 10,
        "requires_ci": true,
        "requires_review": false
      },
      {
        "path": "tests/**",
        "description": "Test additions and repairs that don't change product behavior",
        "max_files": 8,
        "requires_ci": true,
        "requires_review": false
      },
      {
        "path": "scripts/autonomy/**",
        "description": "Autonomy tooling scripts and dispatch logic",
        "max_files": 5,
        "requires_ci": false,
        "requires_review": false,
        "note": "Autonomy tools are self-hosting; CI may not apply"
      },
      {
        "path": "cli/commands/**",
        "description": "CLI command additions that mirror existing API routes (no new contracts)",
        "max_files": 3,
        "requires_ci": true,
        "requires_review": false,
        "conditions": ["no new API routes", "no credential handling changes"]
      },
      {
        "path": "sdk/mutx/**",
        "description": "SDK method additions that mirror existing API routes",
        "max_files": 3,
        "requires_ci": true,
        "requires_review": false,
        "conditions": ["method signature matches OpenAPI contract", "no new endpoints"]
      },
      {
        "path": ".github/workflows/**",
        "description": "CI/workflow changes to existing workflows",
        "max_files": 3,
        "requires_ci": false,
        "requires_review": false
      },
      {
        "path": "infra/monitoring/**",
        "description": "Monitoring, alerting, and observability config additions",
        "max_files": 5,
        "requires_ci": false,
        "requires_review": false
      },
      {
        "path": "src/api/routes/**",
        "description": "PATCH-only route fixes that don't add new endpoints or change contracts",
        "max_files": 3,
        "requires_ci": true,
        "requires_review": false,
        "conditions": ["no new endpoints", "no schema changes", "no auth changes"]
      }
    ]
  },
  "guardrail_rules": {
    "description": "Requires a second agent review before commit. Lane B / staging-first.",
    "rules": [
      {
        "description": "New API route endpoints",
        "paths": ["src/api/routes/**"],
        "conditions": ["new endpoint added", "new HTTP method on existing path"]
      },
      {
        "description": "Schema changes to existing models",
        "paths": ["src/api/models/**", "sdk/mutx/**"]
      },
      {
        "description": "CLI changes that introduce new command groups or change auth flow",
        "paths": ["cli/main.py", "cli/commands/**"]
      },
      {
        "description": "SDK additions for routes not yet in SDK",
        "paths": ["sdk/mutx/**"],
        "conditions": ["new SDK file for unmapped API route"]
      },
      {
        "description": "Database migrations",
        "paths": ["**/migrations/**", "**/alembic/**"]
      },
      {
        "description": "Webhook governance and retry policy changes",
        "paths": ["src/api/services/webhook_service.py", "src/api/routes/webhooks.py"]
      },
      {
        "description": "Auth middleware and ownership check changes",
        "paths": ["src/api/middleware/**", "src/api/security/**"]
      },
      {
        "description": "OpenAPI spec generation and contract changes",
        "paths": ["docs/api/openapi.json", "scripts/generate_openapi.py"]
      },
      {
        "description": "Dashboard pages for previously backend-only routes",
        "paths": ["app/dashboard/**", "app/api/dashboard/**"]
      }
    ]
  },
  "human_block_rules": {
    "description": "Flag these. Do not execute autonomously. Report and halt.",
    "rules": [
      {
        "description": "Credential or secret deletion",
        "paths": ["**/.env*", "**/secrets/**", "**/credentials/**", "src/api/security.py"]
      },
      {
        "description": "Production infrastructure changes",
        "paths": ["infrastructure/terraform/**", "infrastructure/ansible/**", "**/prod/**"]
      },
      {
        "description": "Auth-breaking schema migrations",
        "conditions": ["dropping columns", "renaming user fields", "changing auth schemas"]
      },
      {
        "description": "Third-party API key removal",
        "conditions": ["removing API key env vars", "deleting provider integrations"]
      },
      {
        "description": "Rate limit or quota removal",
        "paths": ["src/api/**"]
      },
      {
        "description": "Webhook destination allowlist bypass",
        "paths": ["src/api/services/webhook_service.py"]
      },
      {
        "description": "Branch protection removal",
        "paths": [".github/branch-protection/**"]
      },
      {
        "description": "Direct main branch commits bypassing CI",
        "note": "Never allow; CI is the gate"
      }
    ]
  },
  "worktree_assignments": {
    "description": "Which worktree to use per agent/area type",
    "backend": {
      "worktree": "~/mutx-worktrees/factory/backend",
      "branches": "backend/**",
      "agent_types": [
        "control-plane-steward",
        "cli-sdk-contract-keeper",
        "runtime-protocol-engineer",
        "infra-delivery-operator",
        "observability-sre",
        "auth-identity-guardian"
      ],
      "areas": ["area:api", "area:cli-sdk", "area:runtime", "area:infra", "area:auth", "area:ops"]
    },
    "frontend": {
      "worktree": "~/mutx-worktrees/factory/frontend",
      "branches": "frontend/**",
      "agent_types": [
        "operator-surface-builder",
        "qa-reliability-engineer"
      ],
      "areas": ["area:web", "area:test"]
    },
    "ship": {
      "worktree": "~/mutx-worktrees/factory/ship",
      "branches": "ship/**",
      "agent_types": [
        "docs-drift-curator",
        "mission-control-orchestrator"
      ],
      "areas": ["area:docs", "area:ops"]
    }
  },
  "dispatch_rules": {
    "stale_claim_minutes": 120,
    "max_patch_bytes": 50000,
    "max_changed_files": 6,
    "required_labels_for_dispatch": ["autonomy:ready", "area:*"],
    "blocking_labels": ["autonomy:blocked", "autonomy:claimed"],
    "reviewer_enforcement": "required_for_all_lanes"
  },
  "lane_definitions": {
    "lane_a_safe": {
      "description": "Auto-merge after CI + one reviewer",
      "labels": ["autonomy:safe", "size:xs", "size:s"],
      "auto_merge": true,
      "staging_required": false
    },
    "lane_b_staging": {
      "description": "Staging deploy gate before merge",
      "labels": ["autonomy:staging", "size:m"],
      "auto_merge": false,
      "staging_required": true
    },
    "lane_c_human": {
      "description": "Human approval required",
      "labels": ["autonomy:blocked", "risk:high"],
      "auto_merge": false,
      "staging_required": true,
      "human_review_required": true
    }
  }
}

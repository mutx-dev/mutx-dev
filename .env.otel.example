# OpenTelemetry Configuration
# Copy to .env and customize for your backend

# Service name (appears in traces)
OTEL_SERVICE_NAME=mutx

# Traces exporter: otlp, jaeger, zipkin, console
OTEL_TRACES_EXPORTER=console

# OTLP Configuration (for Grafana Tempo, Jaeger, etc.)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Jaeger Configuration
OTEL_EXPORTER_JAEGER_AGENT_HOST=localhost
OTEL_EXPORTER_JAEGER_AGENT_PORT=6831

# Zipkin Configuration
OTEL_EXPORTER_ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans

# Sampling configuration
# Options: parentbased_traceidratio, always_on, always_off
OTEL_TRACES_SAMPLER=parentbased_traceidratio
# For parentbased_traceidratio: 0.1 = 10% of traces
OTEL_TRACES_SAMPLER_ARG=0.1

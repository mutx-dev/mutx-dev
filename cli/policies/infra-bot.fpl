# Faramesh Policy Language — infrastructure agent governance
# Strict policy for infrastructure management agents.

agent infra-bot {
  default deny
  model "claude-sonnet-4-20250514"
  framework "autogen"

  budget session {
    max $100
    daily $500
    on_exceed defer
  }

  rules {
    deny! shell/run when cmd matches "rm -rf|DROP TABLE|terraform destroy"
      reason: "destructive command blocked"

    defer shell/run when cmd matches "terraform|kubectl|docker"
      notify: "platform-team"
      reason: "infrastructure change requires approval"

    permit shell/run when cmd matches "ls|cat|grep|find|echo"

    deny * reason: "unlisted tools denied by default"
  }
}

system global {
  version "1.0"
  on_policy_load_failure deny_all
}

# MUTX Environment Configuration
# Copy this file to .env and fill in your values

# Database (Docker PostgreSQL)
DATABASE_URL=postgresql://mutx:mutx_password@localhost:5432/mutx
# Optional when the PostgreSQL proxy rejects SSL upgrade attempts
DATABASE_SSL_MODE=disable

# JWT Secret (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET=replace-with-a-stable-secret

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://app.localhost:3000,https://mutx.dev,https://app.mutx.dev

# Cloudflare Turnstile (required for waitlist signups)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Email (optional)
RESEND_API_KEY=

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=

# Redis
REDIS_URL=redis://localhost:6379/0

# Environment
ENVIRONMENT=development

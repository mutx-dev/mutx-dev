# MUTX Environment Configuration
# Copy this file to .env and fill in your values

# Database (Docker PostgreSQL)
DATABASE_URL=postgresql://mutx:mutx_password@localhost:5432/mutx
# Optional when the PostgreSQL proxy rejects SSL upgrade attempts
DATABASE_SSL_MODE=disable

# JWT Secret (required in production; generate with:
# python3 -c "import secrets; print(secrets.token_urlsafe(32))")
# Leave unset for local development to use an ephemeral auto-generated secret.
# JWT_SECRET=

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://app.localhost:3000,http://pico.localhost:3000,https://mutx.dev,https://app.mutx.dev,https://pico.mutx.dev
PICO_TUTOR_MODEL=gpt-5-mini

# Cloudflare Turnstile (required for waitlist signups)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Email (optional)
RESEND_API_KEY=***
RESEND_AUDIENCE_ID=
RESEND_FROM_EMAIL=MUTX <hello@mutx.dev>
CONTACT_NOTIFY_EMAIL=hello@mutx.dev
LEAD_DISCORD_WEBHOOK_URL=
REQUIRE_EMAIL_VERIFICATION=false
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=72

# Stripe billing (required for Pico paid plans)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# Hosted OAuth providers (optional, but required for Google/GitHub/Discord/Apple auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Apple Sign In (the private key is the .p8 key content from Apple Developer)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=

# Redis
REDIS_URL=redis://localhost:6379/0

# Environment
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
JSON_LOGGING=false
# LOG_FILE=/var/log/mutx/api.log

# Production Environment Variables
# Copy this file to .env.production and fill in your values

# Database
POSTGRES_USER=mutx
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=mutx
DATABASE_URL=postgresql://mutx:your-secure-password@postgres:5432/mutx
# Set this only if your Railway/PostgreSQL endpoint rejects SSL upgrade attempts
# DATABASE_SSL_MODE=disable
DATABASE_REQUIRED_ON_STARTUP=false

# JWT
JWT_SECRET=your-secure-jwt-secret-min-32-chars

# Email
RESEND_API_KEY=re_your_resend_api_key

# URLs
NEXT_PUBLIC_API_URL=https://api.mutx.dev
NEXT_PUBLIC_SITE_URL=https://mutx.dev
CORS_ORIGINS=https://mutx.dev,https://app.mutx.dev
